<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A.S Beauty Collection | Luxury Barber & Parlour</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --bg-color: #121212;
            --text-main: #ffffff;
            --gold-accent: #D4AF37;
            --dark-grey: #1e1e1e;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
        }

        h1, h2, h3 {
            font-family: 'Playfair Display', serif;
            color: var(--gold-accent);
        }

        /* --- Navigation --- */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background-color: rgba(18, 18, 18, 0.98);
            padding: 15px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            border-bottom: 1px solid #333;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--gold-accent);
            text-decoration: none;
        }

        .nav-links {
            list-style: none;
            display: flex;
            gap: 25px;
        }

        .nav-links a {
            color: var(--text-main);
            text-decoration: none;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: var(--gold-accent);
        }

        /* --- Hero Section --- */
        #hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 20px;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), 
                        url('https://images.unsplash.com/photo-1503951914875-452162b0f3f1?q=80&w=2070&auto=format&fit=crop') center/cover;
        }

        #hero h1 {
            font-size: clamp(2.5rem, 8vw, 4.5rem);
            margin-bottom: 15px;
            text-transform: uppercase;
        }

        #hero p {
            font-size: 1.2rem;
            margin-bottom: 35px;
            color: #ddd;
            max-width: 600px;
        }

        .cta-btn {
            padding: 16px 35px;
            background-color: var(--gold-accent);
            color: #000;
            border: none;
            font-weight: 700;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.3s;
            letter-spacing: 1px;
        }

        .cta-btn:hover {
            background-color: #fff;
            transform: translateY(-3px);
        }

        /* --- Sections --- */
        section {
            padding: 100px 8%;
        }

        .section-title {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 60px;
            position: relative;
        }

        .section-title::after {
            content: '';
            width: 60px;
            height: 3px;
            background: var(--gold-accent);
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
        }

        /* --- Services Grid --- */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 40px;
        }

        .service-card {
            background: var(--dark-grey);
            padding: 50px 30px;
            text-align: center;
            border: 1px solid #333;
            transition: 0.4s;
        }

        .service-card:hover {
            border-color: var(--gold-accent);
            background: #252525;
        }

        .service-card i {
            font-size: 3.5rem;
            color: var(--gold-accent);
            margin-bottom: 25px;
        }

        .service-card h3 {
            margin-bottom: 15px;
            color: #fff;
        }

        /* --- Info & Timing --- */
        .info-wrapper {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
            margin-bottom: 50px;
        }

        .info-card {
            background: var(--dark-grey);
            padding: 40px;
            border-left: 4px solid var(--gold-accent);
        }

        .info-card h3 {
            margin-bottom: 25px;
            font-size: 1.5rem;
        }

        .contact-item {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            margin-bottom: 20px;
        }

        .contact-item i {
            color: var(--gold-accent);
            margin-top: 5px;
        }

        .timing-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid #333;
        }

        .timing-row:last-child {
            border-bottom: none;
            color: var(--gold-accent);
            font-weight: 600;
        }

        /* --- Map --- */
        .map-box {
            width: 100%;
            height: 450px;
            border: 1px solid #444;
            filter: grayscale(0.5) contrast(1.2) invert(0.9) hue-rotate(180deg); /* Dark mode map look */
        }

        /* --- Footer --- */
        footer {
            padding: 40px;
            text-align: center;
            background: #000;
            border-top: 1px solid #222;
            color: #666;
            font-size: 0.9rem;
        }

        /* --- Back to Top --- */
        #backToTop {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--gold-accent);
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: none;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            z-index: 1001;
            color: #000;
        }

        @media (max-width: 768px) {
            .nav-links { display: none; }
            section { padding: 60px 5%; }
            .info-wrapper { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <nav>
        <a href="#" class="logo">A.S BEAUTY</a>
        <ul class="nav-links">
            <li><a href="#hero">Home</a></li>
            <li><a href="#services">Services</a></li>
            <li><a href="#details">Contact</a></li>
        </ul>
    </nav>

    <section id="hero">
        <h1>A.S Beauty Collection</h1>
        <p>Redefining Your Style with Premium Grooming & Parlour Services</p>
        <button class="cta-btn" onclick="handleQuery()">Inquiry / Book Now</button>
    </section>

    <section id="services">
        <h2 class="section-title">Our Expertise</h2>
        <div class="services-grid">
            <div class="service-card">
                <i class="fa-solid fa-scissors"></i>
                <h3>Hair Styling</h3>
                <p>Expert haircuts for men and women including fade cuts, layers, and bridal styling.</p>
            </div>
            <div class="service-card">
                <i class="fa-solid fa-wind"></i>
                <h3>Beauty Parlour</h3>
                <p>Relaxing facials, hair spa, and complete makeup collections for all occasions.</p>
            </div>
            <div class="service-card">
                <i class="fa-solid fa-bolt"></i>
                <h3>Grooming</h3>
                <p>Modern trimmer styling, beard grooming, and luxury shaves for a sharp look.</p>
            </div>
        </div>
    </section>

    <section id="details">
        <h2 class="section-title">Find Us</h2>
        <div class="info-wrapper">
            <div class="info-card">
                <h3>Contact Details</h3>
                <div class="contact-item">
                    <i class="fa-solid fa-location-dot"></i>
                    <span>G10 Royal Avenue, Opp. Summit Hotel, Unn, Surat - 394210</span>
                </div>
                <div class="contact-item">
                    <i class="fa-solid fa-phone"></i>
                    <span>+91 9712556032</span>
                </div>
                <div class="contact-item">
                    <i class="fa-solid fa-envelope"></i>
                    <span>info@asbeautycollection.com</span>
                </div>
            </div>

            <div class="info-card">
                <h3>Business Hours</h3>
                <div class="timing-row">
                    <span>Mon - Sat</span>
                    <span>9:00 AM - 9:00 PM</span>
                </div>
                <div class="timing-row">
                    <span>Sunday</span>
                    <span>9:00 AM - 5:00 PM</span>
                </div>
            </div>
        </div>

        <div class="map-box">
            <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3721.46513463878!2d72.853039!3d21.1338879!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be051469eddb7bf%3A0xda7452fc1a3bfb24!2sA.S%20Beauty%20Collection!5e0!3m2!1sen!2sin!4v1712600000000!5m2!1sen!2sin" 
                width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy">
            </iframe>
        </div>
    </section>

    <footer>
        <p>&copy; 2026 A.S Beauty Collection. All Rights Reserved.</p>
    </footer>

    <div id="backToTop"><i class="fa-solid fa-arrow-up"></i></div>

    <script>
        // Inquiry Button Action
        function handleQuery() {
            alert("Welcome to A.S Beauty Collection!\n\nPlease call us at 9712556032 to book your slot or visit our shop in Unn, Surat.");
        }

        // Back to Top Logic
        const topBtn = document.getElementById("backToTop");
        window.onscroll = function() {
            if (document.body.scrollTop > 400 || document.documentElement.scrollTop > 400) {
                topBtn.style.display = "flex";
            } else {
                topBtn.style.display = "none";
            }
        };

        topBtn.onclick = function() {
            window.scrollTo({top: 0, behavior: 'smooth'});
        };
    </script>
</body>
</html>

